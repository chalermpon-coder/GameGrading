import React, { useState, useCallback } from 'react';
import { Upload, CheckCircle, FileText, User, Hash, GraduationCap, List, Loader2, Image as ImageIcon, X } from 'lucide-react';

const App = () => {
  const [step, setStep] = useState('form'); // form, uploading, success
  const [error, setError] = useState(null);
  const [formData, setFormData] = useState({
    fullName: '',
    studentId: '',
    gradeClass: '',
    assignmentNumber: '1',
    file: null,
    filePreview: null
  });
  const [isSubmitting, setIsSubmitting] = useState(false);

  // ใส่ URL ที่ได้จากการ Deploy Google Apps Script ที่นี่
  const GAS_URL = "https://script.google.com/macros/s/AKfycbyhQ1A5IekYhRmouqsdJ5gMeP3yxHjoIqVo7fkdNypOi7WXJMQY_JghuCFCf7W4t0l1/exec"; 

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleFileChange = (e) => {
    const file = e.target.files[0];
    if (file && file.type.startsWith('image/')) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setFormData(prev => ({
          ...prev,
          file: file,
          filePreview: reader.result
        }));
      };
      reader.readAsDataURL(file);
    }
  };

  const removeFile = () => {
    setFormData(prev => ({ ...prev, file: null, filePreview: null }));
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (!formData.file) return;

    setIsSubmitting(true);
    setError(null);
    
    try {
      // หากยังไม่ได้ใส่ URL จะทำการจำลอง (Simulate) ให้ดู
      if (!GAS_URL) {
        await new Promise(resolve => setTimeout(resolve, 2000));
        setStep('success');
        return;
      }

      // เตรียมข้อมูลส่งไปยัง Google Apps Script
      const payload = {
        fullName: formData.fullName,
        studentId: formData.studentId,
        gradeClass: formData.gradeClass,
        assignmentNumber: formData.assignmentNumber,
        fileName: formData.file.name,
        fileData: formData.filePreview // ส่งแบบ Base64
      };

      const response = await fetch(GAS_URL, {
        method: 'POST',
        mode: 'no-cors', // ใช้ no-cors สำหรับ Google Apps Script ในบางกรณี
        body: JSON.stringify(payload),
      });

      // เนื่องจาก no-cors จะอ่าน response ไม่ได้ เราจะถือว่าถ้าไม่ throw error คือสำเร็จ
      // หรือถ้าแก้ GAS ให้รองรับ CORS จะใช้ response.json() ได้ปกติ
      setStep('success');
      
    } catch (err) {
      console.error(err);
      setError('ไม่สามารถส่งข้อมูลได้ กรุณาตรวจสอบการเชื่อมต่อ Google Script');
    } finally {
      setIsSubmitting(false);
    }
  };

  const resetForm = () => {
    setFormData({
      fullName: '',
      studentId: '',
      gradeClass: '',
      assignmentNumber: '1',
      file: null,
      filePreview: null
    });
    setError(null);
    setStep('form');
  };

  return (
    <div className="min-h-screen bg-slate-50 flex items-center justify-center p-4 font-sans text-slate-900">
      <div className="max-w-md w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
        
        {/* Header */}
        <div className="bg-blue-600 p-8 text-white text-center">
          <div className="inline-flex items-center justify-center w-16 h-16 bg-white/20 rounded-2xl mb-4 backdrop-blur-sm">
            <FileText size={32} />
          </div>
          <h1 className="text-2xl font-bold text-white">ระบบส่งงานออนไลน์</h1>
          <p className="text-blue-100 mt-1 opacity-90">กรุณากรอกข้อมูลให้ครบถ้วนเพื่อส่งงาน</p>
        </div>

        {step === 'form' && (
          <form onSubmit={handleSubmit} className="p-8 space-y-5">
            {error && (
              <div className="p-3 bg-red-50 border border-red-100 text-red-600 text-sm rounded-xl">
                {error}
              </div>
            )}

            {/* Full Name */}
            <div>
              <label className="flex items-center text-sm font-semibold text-slate-700 mb-1">
                <User size={16} className="mr-2 text-blue-500" /> ชื่อ-นามสกุล
              </label>
              <input
                required
                type="text"
                name="fullName"
                value={formData.fullName}
                onChange={handleInputChange}
                className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                placeholder="ด.ช. สมชาย ใจดี"
              />
            </div>

            <div className="grid grid-cols-2 gap-4">
              {/* Student ID */}
              <div>
                <label className="flex items-center text-sm font-semibold text-slate-700 mb-1">
                  <Hash size={16} className="mr-2 text-blue-500" /> เลขที่
                </label>
                <input
                  required
                  type="number"
                  name="studentId"
                  value={formData.studentId}
                  onChange={handleInputChange}
                  className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                  placeholder="01"
                />
              </div>

              {/* Class */}
              <div>
                <label className="flex items-center text-sm font-semibold text-slate-700 mb-1">
                  <GraduationCap size={16} className="mr-2 text-blue-500" /> ชั้น
                </label>
                <input
                  required
                  type="text"
                  name="gradeClass"
                  value={formData.gradeClass}
                  onChange={handleInputChange}
                  className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all"
                  placeholder="ม.1/1"
                />
              </div>
            </div>

            {/* Assignment Dropdown */}
            <div>
              <label className="flex items-center text-sm font-semibold text-slate-700 mb-1">
                <List size={16} className="mr-2 text-blue-500" /> เลือกงานที่ส่ง
              </label>
              <select
                name="assignmentNumber"
                value={formData.assignmentNumber}
                onChange={handleInputChange}
                className="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all appearance-none"
              >
                {[1, 2, 3, 4, 5].map(num => (
                  <option key={num} value={num}>งานที่ {num}</option>
                ))}
              </select>
            </div>

            {/* File Upload */}
            <div>
              <label className="flex items-center text-sm font-semibold text-slate-700 mb-1">
                <ImageIcon size={16} className="mr-2 text-blue-500" /> อัปโหลดไฟล์ภาพงาน
              </label>
              
              {!formData.filePreview ? (
                <div className="relative group">
                  <input
                    required
                    type="file"
                    accept="image/*"
                    onChange={handleFileChange}
                    className="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
                  />
                  <div className="border-2 border-dashed border-slate-300 rounded-2xl p-8 flex flex-col items-center justify-center group-hover:border-blue-400 group-hover:bg-blue-50 transition-all">
                    <Upload className="text-slate-400 group-hover:text-blue-500 mb-2" size={32} />
                    <p className="text-sm text-slate-500 group-hover:text-blue-600 font-medium text-center">คลิกเพื่อเลือกไฟล์ หรือลากไฟล์มาวาง</p>
                    <p className="text-xs text-slate-400 mt-1">รองรับไฟล์ JPG, PNG</p>
                  </div>
                </div>
              ) : (
                <div className="relative rounded-2xl overflow-hidden border border-slate-200 group">
                  <img 
                    src={formData.filePreview} 
                    alt="Preview" 
                    className="w-full h-48 object-cover"
                  />
                  <div className="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <button 
                      type="button"
                      onClick={removeFile}
                      className="p-2 bg-red-500 text-white rounded-full hover:bg-red-600 transition-colors"
                    >
                      <X size={20} />
                    </button>
                  </div>
                  <div className="p-2 bg-slate-50 text-xs text-slate-600 border-t border-slate-200 flex justify-between items-center">
                    <span className="truncate max-w-[150px]">{formData.file?.name}</span>
                    <span className="font-semibold text-blue-600">พร้อมส่ง</span>
                  </div>
                </div>
              )}
            </div>

            {/* Submit Button */}
            <button
              disabled={isSubmitting || !formData.file}
              type="submit"
              className={`w-full py-3.5 rounded-xl font-bold text-white shadow-lg transition-all transform active:scale-95 flex items-center justify-center space-x-2 ${
                isSubmitting || !formData.file 
                  ? 'bg-slate-400 cursor-not-allowed' 
                  : 'bg-blue-600 hover:bg-blue-700 hover:shadow-blue-200'
              }`}
            >
              {isSubmitting ? (
                <>
                  <Loader2 className="animate-spin" size={20} />
                  <span>กำลังบันทึกข้อมูล...</span>
                </>
              ) : (
                <span>ส่งงานตอนนี้</span>
              )}
            </button>
          </form>
        )}

        {step === 'success' && (
          <div className="p-12 text-center flex flex-col items-center">
            <div className="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-6 animate-bounce">
              <CheckCircle size={48} />
            </div>
            <h2 className="text-2xl font-bold text-slate-800 mb-2">ส่งงานสำเร็จ!</h2>
            <p className="text-slate-500 mb-8">
              ระบบได้บันทึกข้อมูลและไฟล์ภาพลงใน <span className="font-semibold">Google Drive</span> และ <span className="font-semibold">Sheets</span> เรียบร้อยแล้ว
            </p>
            <button
              onClick={resetForm}
              className="px-8 py-2.5 bg-slate-100 text-slate-700 font-semibold rounded-xl hover:bg-slate-200 transition-colors"
            >
              ส่งงานเพิ่ม
            </button>
          </div>
        )}

        {/* Footer Info */}
        <div className="px-8 pb-8 text-center">
          <p className="text-[10px] text-slate-400 uppercase tracking-widest font-bold">
            ระบบจัดเก็บข้อมูลอัตโนมัติผ่าน Cloud Storage
          </p>
        </div>
      </div>
    </div>
  );
};

export default App;
