<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบส่งงานออนไลน์ - Assignment Submission</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <!-- Babel for JSX -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap');
        body { font-family: 'Sarabun', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;
        
        // Mocking Lucide icons for the script environment
        const Icon = ({ name, size = 20, className = "" }) => {
            return <i data-lucide={name} style={{ width: size, height: size }} className={className}></i>;
        };

        const App = () => {
            const [step, setStep] = useState('form');
            const [error, setError] = useState(null);
            const [isSubmitting, setIsSubmitting] = useState(false);
            const [formData, setFormData] = useState({
                fullName: '',
                studentId: '',
                gradeClass: '',
                assignmentNumber: '1',
                file: null,
                filePreview: null
            });

            // ใส่ URL ที่ได้จาก Google Apps Script ที่นี่
            const GAS_URL = "https://script.google.com/macros/s/AKfycbyhQ1A5IekYhRmouqsdJ5gMeP3yxHjoIqVo7fkdNypOi7WXJMQY_JghuCFCf7W4t0l1/exec";

            React.useEffect(() => {
                if (window.lucide) {
                    window.lucide.createIcons();
                }
            }, [step, formData.filePreview, error]);

            const handleInputChange = (e) => {
                const { name, value } = e.target;
                setFormData(prev => ({ ...prev, [name]: value }));
            };

            const handleFileChange = (e) => {
                const file = e.target.files[0];
                if (file && file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onloadend = () => {
                        setFormData(prev => ({
                            ...prev,
                            file: file,
                            filePreview: reader.result
                        }));
                    };
                    reader.readAsDataURL(file);
                }
            };

            const removeFile = () => {
                setFormData(prev => ({ ...prev, file: null, filePreview: null }));
            };

            const handleSubmit = async (e) => {
                e.preventDefault();
                if (!formData.file) return;

                setIsSubmitting(true);
                setError(null);
                
                try {
                    const payload = {
                        fullName: formData.fullName,
                        studentId: formData.studentId,
                        gradeClass: formData.gradeClass,
                        assignmentNumber: formData.assignmentNumber,
                        fileName: formData.file.name,
                        fileData: formData.filePreview
                    };

                    await fetch(GAS_URL, {
                        method: 'POST',
                        mode: 'no-cors',
                        body: JSON.stringify(payload),
                    });

                    setStep('success');
                } catch (err) {
                    setError('เกิดข้อผิดพลาดในการส่งข้อมูล กรุณาลองใหม่อีกครั้ง');
                } finally {
                    setIsSubmitting(false);
                }
            };

            const resetForm = () => {
                setFormData({
                    fullName: '',
                    studentId: '',
                    gradeClass: '',
                    assignmentNumber: '1',
                    file: null,
                    filePreview: null
                });
                setStep('form');
            };

            return (
                <div className="min-h-screen flex items-center justify-center p-4">
                    <div className="max-w-md w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-100">
                        <div className="bg-blue-600 p-8 text-white text-center">
                            <h1 className="text-2xl font-bold">ระบบส่งงานออนไลน์</h1>
                            <p className="text-blue-100 mt-1 opacity-90">กรุณากรอกข้อมูลเพื่อส่งงาน</p>
                        </div>

                        {step === 'form' ? (
                            <form onSubmit={handleSubmit} className="p-8 space-y-5">
                                {error && <div className="p-3 bg-red-50 text-red-600 text-sm rounded-xl">{error}</div>}
                                
                                <div>
                                    <label className="block text-sm font-semibold text-slate-700 mb-1">ชื่อ-นามสกุล</label>
                                    <input required type="text" name="fullName" value={formData.fullName} onChange={handleInputChange} className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="ระบุชื่อ-นามสกุล" />
                                </div>

                                <div className="grid grid-cols-2 gap-4">
                                    <div>
                                        <label className="block text-sm font-semibold text-slate-700 mb-1">เลขที่</label>
                                        <input required type="number" name="studentId" value={formData.studentId} onChange={handleInputChange} className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="01" />
                                    </div>
                                    <div>
                                        <label className="block text-sm font-semibold text-slate-700 mb-1">ชั้น</label>
                                        <input required type="text" name="gradeClass" value={formData.gradeClass} onChange={handleInputChange} className="w-full px-4 py-2.5 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="ม.1/1" />
                                    </div>
                                </div>

                                <div>
                                    <label className="block text-sm font-semibold text-slate-700 mb-1">เลือกงานที่ส่ง</label>
                                    <select name="assignmentNumber" value={formData.assignmentNumber} onChange={handleInputChange} className="w-full px-4 py-2.5 rounded-xl border border-slate-200 bg-white focus:ring-2 focus:ring-blue-500 outline-none">
                                        {[1, 2, 3, 4, 5].map(num => <option key={num} value={num}>งานที่ {num}</option>)}
                                    </select>
                                </div>

                                <div>
                                    <label className="block text-sm font-semibold text-slate-700 mb-1">อัปโหลดไฟล์ภาพ</label>
                                    {!formData.filePreview ? (
                                        <div className="relative border-2 border-dashed border-slate-300 rounded-2xl p-8 flex flex-col items-center justify-center hover:bg-blue-50 transition-all cursor-pointer">
                                            <input required type="file" accept="image/*" onChange={handleFileChange} className="absolute inset-0 opacity-0 cursor-pointer" />
                                            <span className="text-sm text-slate-500 font-medium text-center">เลือกไฟล์ภาพงาน</span>
                                        </div>
                                    ) : (
                                        <div className="relative rounded-2xl overflow-hidden border border-slate-200">
                                            <img src={formData.filePreview} className="w-full h-40 object-cover" />
                                            <button type="button" onClick={removeFile} className="absolute top-2 right-2 p-1 bg-red-500 text-white rounded-full">×</button>
                                        </div>
                                    )}
                                </div>

                                <button disabled={isSubmitting || !formData.file} type="submit" className="w-full py-3.5 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 disabled:bg-slate-400 transition-all">
                                    {isSubmitting ? 'กำลังส่งงาน...' : 'ส่งงานตอนนี้'}
                                </button>
                            </form>
                        ) : (
                            <div className="p-12 text-center">
                                <h2 className="text-2xl font-bold text-slate-800 mb-2">ส่งงานสำเร็จ!</h2>
                                <p className="text-slate-500 mb-8 text-sm">ข้อมูลถูกบันทึกลงในระบบเรียบร้อยแล้ว</p>
                                <button onClick={resetForm} className="px-8 py-2.5 bg-slate-100 text-slate-700 rounded-xl font-semibold">ส่งงานเพิ่ม</button>
                            </div>
                        )}
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
